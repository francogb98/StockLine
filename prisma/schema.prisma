generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id             String        @id @default(uuid())
  name           String
  address        String
  phone          String
  config         Json?
  createdAt      DateTime      @default(now())

  users          User[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  cashSessions   CashSession[]
  stockMovements StockMovement[]
  subscription   Subscription?
  suspendedSales SuspendedSale[]

  @@map("stores")
}

model Subscription {
  id                       String    @id @default(uuid())
  storeId                  String    @unique
  store                    Store     @relation(fields: [storeId], references: [id])
  status                   String
  plan                     String
  currentPeriodStart       DateTime
  currentPeriodEnd         DateTime
  trialEndsAt              DateTime?
  mercadoPagoPreapprovalId String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("subscriptions")
}

model User {
  id                     String   @id @default(uuid())
  storeId                String
  store                  Store    @relation(fields: [storeId], references: [id])
  email                  String   @unique
  name                   String
  role                   String
  passwordHash           String   @db.VarChar(255)
  hasCompletedOnboarding Boolean  @default(false)
  onboardingStep         Int      @default(0)
  draftOnboardingState   Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  sales                    Sale[]
  cashSessions             CashSession[]
  stockMovements           StockMovement[]
  sessions                 Session[]
  suspendedSales           SuspendedSale[]
  productions              Production[]
  ingredientStockMovements IngredientStockMovement[]

  @@map("users")
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id             String  @id @default(uuid())
  storeId        String
  store          Store   @relation(fields: [storeId], references: [id])
  name           String
  normalizedName String  @default("")
  description    String?

  products Product[]

  @@unique([storeId, normalizedName])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  barcode     String?  @unique
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @db.Decimal(12, 2)
  stock       Int
  minStock    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItems      SaleItem[]
  stockMovements StockMovement[]
  recipe         Recipe?

  @@map("products")
}

model Sale {
  id            String       @id @default(uuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])
  subtotal      Decimal      @db.Decimal(12, 2)
  tax           Decimal      @db.Decimal(12, 2)
  total         Decimal      @db.Decimal(12, 2)
  paymentMethod String
  status        String       @default("completed")
  createdAt     DateTime     @default(now())

  items SaleItem[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([cashSessionId])
  @@map("sales")
}

model CashSession {
  id             String    @id @default(uuid())
  storeId        String
  store          Store     @relation(fields: [storeId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  openingAmount  Decimal   @db.Decimal(12, 2) @default(0)
  expectedAmount Decimal?  @db.Decimal(12, 2)
  closingAmount  Decimal?  @db.Decimal(12, 2)
  difference     Decimal?  @db.Decimal(12, 2)
  notes          String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())

  sales Sale[]

  @@index([storeId, closedAt])
  @@index([storeId, createdAt])
  @@map("cash_sessions")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@map("sale_items")
}

enum MovementType {
  SALE
  RETURN
  MANUAL_ADJUSTMENT
  PRODUCT_CREATION
  IMPORT
  STOCK_CORRECTION
  CANCELLATION
}

model StockMovement {
  id            String       @id @default(uuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  type          MovementType
  quantity      Int
  previousStock Int
  newStock      Int
  referenceId   String?
  reason        String?
  createdAt     DateTime     @default(now())

  @@index([productId, createdAt(sort: Desc)])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([referenceId])
  @@map("stock_movements")
}

model SuspendedSale {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  total     Decimal  @db.Decimal(12, 2)
  itemCount Int
  createdAt DateTime @default(now())

  items SuspendedSaleItem[]

  @@index([storeId, createdAt(sort: Desc)])
  @@map("suspended_sales")
}

model SuspendedSaleItem {
  id              String        @id @default(uuid())
  suspendedSaleId String
  suspendedSale   SuspendedSale @relation(fields: [suspendedSaleId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)

  @@index([suspendedSaleId])
  @@map("suspended_sale_items")
}

// ============================================================
// INGREDIENTS & RECIPES (Phase 6-8)
// ============================================================

model IngredientCategory {
  id          String  @id @default(uuid())
  storeId     String
  name        String
  description String?

  ingredients Ingredient[]

  @@unique([storeId, name])
  @@map("ingredient_categories")
}

model Ingredient {
  id          String              @id @default(uuid())
  storeId     String
  name        String
  description String?
  unit        String
  cost        Decimal             @db.Decimal(12, 2) @default(0)
  stock       Decimal             @db.Decimal(12, 2) @default(0)
  minStock    Decimal             @db.Decimal(12, 2) @default(0)
  categoryId  String?
  category    IngredientCategory? @relation(fields: [categoryId], references: [id])
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  recipeItems      RecipeIngredient[]
  stockMovements   IngredientStockMovement[]
  productionUsages ProductionUsage[]

  @@index([storeId, isActive])
  @@index([storeId, categoryId])
  @@map("ingredients")
}

model Recipe {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  description String?
  productId   String?  @unique
  product     Product? @relation(fields: [productId], references: [id])
  yield       Decimal  @db.Decimal(12, 2) @default(1)
  yieldUnit   String   @default("unit")
  prepTime    Int?
  cost        Decimal  @db.Decimal(12, 2) @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients RecipeIngredient[]
  productions Production[]

  @@index([storeId, isActive])
  @@map("recipes")
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(12, 2)
  unit         String
  sortOrder    Int        @default(0)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model Production {
  id          String           @id @default(uuid())
  storeId     String
  recipeId    String
  recipe      Recipe           @relation(fields: [recipeId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  quantity    Decimal          @db.Decimal(12, 2)
  status      ProductionStatus @default(PENDING)
  notes       String?
  startedAt   DateTime         @default(now())
  completedAt DateTime?

  usages ProductionUsage[]

  @@index([storeId, status])
  @@map("productions")
}

model ProductionUsage {
  id           String     @id @default(uuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantityUsed Decimal    @db.Decimal(12, 2)
  costAtTime   Decimal    @db.Decimal(12, 2)

  @@map("production_usages")
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IngredientMovementType {
  PURCHASE
  PRODUCTION
  ADJUSTMENT
  WASTE
  RETURN
}

model IngredientStockMovement {
  id            String                 @id @default(uuid())
  storeId       String
  ingredientId  String
  ingredient    Ingredient             @relation(fields: [ingredientId], references: [id])
  userId        String
  user          User                   @relation(fields: [userId], references: [id])
  type          IngredientMovementType
  quantity      Decimal                @db.Decimal(12, 2)
  previousStock Decimal                @db.Decimal(12, 2)
  newStock      Decimal                @db.Decimal(12, 2)
  costPerUnit   Decimal?               @db.Decimal(12, 2)
  referenceId   String?
  reason        String?
  createdAt     DateTime               @default(now())

  @@index([ingredientId, createdAt(sort: Desc)])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("ingredient_stock_movements")
}
