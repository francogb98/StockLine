# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/database"

# Modo mock (1 = usar datos mock, 0 = usar DB real)
NEXT_PUBLIC_USE_MOCK_DATA=0

# Mercado Pago - Access Token (https://www.mercadopago.com.ar/developers)
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-xxxx-xxxxx-xxxxx"

# Mercado Pago - Webhook Secret (para validar webhooks entrantes)
MERCADO_PAGO_WEBHOOK_SECRET="tu_webhook_secret"

# URL pública de la app (para webhooks y links de pago)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
